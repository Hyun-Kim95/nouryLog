generator client {
  provider = "prisma-client-js"
}

// 기본 DB: PostgreSQL
// 예) postgresql://diet:diet@localhost:5432/diet?schema=public
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  role          UserRole  @default(USER)
  active        Boolean   @default(true)
  deactivatedAt DateTime?
  /// 마지막 로그인 시각. 이메일/리프레시/소셜 로그인 성공 시 갱신.
  lastLoginAt   DateTime?
  /// 비활성화 사유 코드. 'spam' | 'inactive_long' | 'terms_violation' | 'etc'.
  deactivationReasonCode String?
  /// 비활성화 사유 자유 입력(최대 500자). `etc` 코드일 때 필수, 그 외엔 선택.
  deactivationReason     String?
  createdAt     DateTime  @default(now())
  freeOcrUsed   Int       @default(0)

  profile Profile?
  meals   Meal[]
  billing Billing?
  socialAccounts SocialAccount[]
  consents UserConsent[]
}

enum SocialProvider {
  NAVER
  GOOGLE
  KAKAO
}

/// 템플릿 1단위 표시·입력 UX 힌트. `servingGrams`는 항상 그 1단위의 질량(g).
enum PortionUnit {
  GRAM
  PIECE
  PLATE
  BOWL
  CUSTOM
}

enum MealInputMode {
  PORTION_COUNT
  TOTAL_GRAMS
}

enum MealSlot {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum SnackPlacement {
  BEFORE_BREAKFAST
  BETWEEN_BREAKFAST_LUNCH
  BETWEEN_LUNCH_DINNER
  AFTER_DINNER
}

model SocialAccount {
  id             String         @id @default(cuid())
  provider       SocialProvider
  providerUserId String
  email          String?
  userId         String
  linkedAt       DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model Profile {
  userId          String  @id
  gender          String  @default("unspecified")
  age             Int     @default(30)
  heightCm        Int     @default(170)
  weightKg        Float   @default(70)
  /// `sedentary` / `light` / `moderate` / `active`. NULL이면 권장 계산 시 임시 기본값 `moderate` 적용.
  activityLevel   String?
  /// `lose` / `maintain` / `gain`. NULL이면 권장 계산 시 임시 기본값 `maintain` 적용.
  goal            String?
  proteinGoalG         Int?
  calorieGoalKcal      Int?
  proteinGoalMinG      Int?
  proteinGoalMaxG      Int?
  calorieGoalMinKcal   Int?
  calorieGoalMaxKcal   Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Meal {
  id           String   @id @default(cuid())
  userId       String
  note         String?
  consumedAt   DateTime
  name         String
  grams        Float    @default(100)
  calories     Float
  carbohydrate Float
  protein      Float
  fat          Float
  imageUrl     String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  foodTemplateId  String?
  mealInputMode   MealInputMode?
  /// `PORTION_COUNT`일 때만 값이 있음. `TOTAL_GRAMS` 모드에서는 null.
  portionQuantity Float?
  /// 아침/점심/저녁/추가(간식). 레거시 row는 null.
  mealSlot        MealSlot?
  /// `mealSlot === SNACK`일 때만 사용. 끼니 사이 위치.
  snackPlacement  SnackPlacement?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodTemplate FoodTemplate? @relation(fields: [foodTemplateId], references: [id], onDelete: SetNull)

  @@index([userId, consumedAt])
  @@index([foodTemplateId])
}

model FoodTemplate {
  id        String   @id @default(cuid())
  name      String
  memo      String?
  category  String?
  portionUnit  PortionUnit @default(GRAM)
  portionLabel String?
  /// 기준 분량의 숫자(예: 100+g, 1개, 1.5접시). 그램 단위일 때는 보통 `servingGrams`와 동일.
  referenceAmount Float @default(1)
  /// 영양 4필드가 해당하는 총 질량(g). `portionUnit`이 GRAM이면 `referenceAmount`와 동일하게 맞춘다.
  servingGrams Float?
  /// 기준 분량당 칼로리(kcal). 신규/수정 시 필수, 기존 행 NULL 허용.
  calories     Float?
  /// 기준 분량당 단백질(g). 신규/수정 시 필수.
  protein      Float?
  /// 기준 분량당 지방(g). 신규/수정 시 필수.
  fat          Float?
  /// 기준 분량당 탄수화물(g). 신규/수정 시 필수.
  carbohydrate Float?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  meals Meal[]

  @@index([category])
}

model Inquiry {
  id          String    @id @default(cuid())
  userId      String?
  subject     String
  body        String
  status      String    @default("pending")
  active      Boolean   @default(true)
  answer      String?
  answeredAt  DateTime?
  answeredBy  String?
  createdAt   DateTime  @default(now())

  @@index([status, active])
}

model Notice {
  id        String   @id @default(cuid())
  title     String
  body      String
  active    Boolean  @default(true)
  /// 상단 고정 여부. true면 목록 정렬 우선.
  pinned    Boolean  @default(false)
  /// 게시 시작 시각(선택). 둘 다 있을 때만 start <= end 검증.
  publishStart DateTime?
  /// 게시 종료 시각(선택). null이면 무기한.
  publishEnd   DateTime?
  createdAt DateTime @default(now())
}

model Billing {
  userId         String  @id
  ocrPaidEnabled Boolean @default(false)
  adFreeEnabled  Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StatsBatch {
  id        String   @id @default("singleton")
  lastRunAt DateTime @default(now())
}

/// 사용자의 약관·개인정보처리방침 동의 이력. 정책 개정 시 버전별 동의 기록을 남긴다.
model UserConsent {
  id            String   @id @default(cuid())
  userId        String
  /// 'terms' | 'privacy'. 라우트에서 검증한다.
  kind          String
  policyVersion Int
  acceptedAt    DateTime @default(now())
  /// 'email-signup' | 'social-signup:google' 같은 유입 경로.
  source        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind])
}

/// 이용약관·개인정보처리방침 같은 정책 문서. kind 단일성으로 종류별 단일 본문을 유지한다.
model PolicyDocument {
  id          String    @id @default(cuid())
  /// 'terms' | 'privacy'. 라우트에서 검증한다.
  kind        String    @unique
  body        String
  /// 저장 시 +1. 외부 노출은 publishedAt 으로 판단.
  version     Int       @default(1)
  /// publish 체크 시 채워지고, 비공개로 되돌리면 null.
  publishedAt DateTime?
  updatedAt   DateTime  @updatedAt
}
