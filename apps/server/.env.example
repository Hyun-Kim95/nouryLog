DATABASE_URL="postgresql://diet:diet@localhost:5432/diet?schema=public"
JWT_SECRET="change-me-in-production-min-32-chars-long!!"
PORT=3000
UPLOAD_DIR="./uploads"
# OCR 무료 한도(월, Asia/Seoul). 활성 USER > threshold 이면 REDUCED 적용
OCR_FREE_LIMIT_NORMAL=10
OCR_FREE_LIMIT_REDUCED=5
OCR_FREE_USER_THRESHOLD=100
STATS_STALE_HOURS=6
# Android 앱 버전 안내 (권장 latest는 Play production versionCode 자동 조회)
APP_ANDROID_MIN_VERSION="1.0.0"
# 강제 업데이트 versionCode (0이면 semver minVersion만 사용)
APP_ANDROID_MIN_VERSION_CODE="0"
# Play API 실패 시에만 권장 업데이트 semver fallback
APP_ANDROID_LATEST_VERSION="1.0.0"
APP_ANDROID_STORE_URL="https://play.google.com/store/apps/details?id=com.nourylog.app"
# PLAY_VERSION_DEBUG=1
# Google Cloud Vision API 키 (Cloud Console > API 및 서비스 > 사용자 인증 정보)
# Railway 등 호스팅: 키 값에 따옴표 없이 붙여넣기. 앱 제한(Android/iOS만)이면 서버 호출 실패.
# 실패 원인 확인: OCR_DEBUG=1 후 재배포 → deploy 로그에 [ocr] vision request failed
OCR_PROVIDER="google_vision"
OCR_API_KEY=""
OCR_API_URL="https://vision.googleapis.com/v1/images:annotate"
OAUTH_SERVER_BASE_URL="http://localhost:3000"
OAUTH_STATE_SECRET="change-me-social-state-secret"
# 로컬/Railway 로그에서 네이버·카카오 토큰/프로필 실패 원인 확인 시: SOCIAL_OAUTH_DEBUG=1
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
# 구글 idToken 검증용 — 클라이언트 SDK 의 webClientId 와 동일한 값을 쉼표로 구분해 등록.
# 비어 있으면 aud 검증을 건너뛰지만(로컬 개발 편의) 운영에서는 반드시 채워야 한다.
GOOGLE_ALLOWED_AUDIENCES=""

# Google Play Billing (Android 구독 검증) — Play Console API 액세스 연동 후 설정
GOOGLE_PLAY_PACKAGE_NAME="com.nourylog.app"
GOOGLE_PLAY_SUBSCRIPTION_ID="premium_monthly"
# 서비스 계정 JSON 전체(한 줄) 또는 base64 인코딩 문자열. 레포에 커밋하지 말 것.
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=""
# 로컬 개발만: Play 검증 없이 checkout/restore 허용 (production 배포 금지)
# BILLING_SKIP_VERIFY=1

# 하단 배너 광고(전역). 미설정·0 = 모든 사용자 미노출. 1/true 로 켜면 adFree 미구독자에게 노출
# ADS_BOTTOM_BANNER_ENABLED=1
