{
  "name": "@diet-management/server",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:release": "prisma migrate deploy && node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "purge:inactive": "tsx scripts/purge-inactive.mjs",
    "test": "node --import tsx --test ./src/appVersion.test.ts ./src/appVersion.resolve.test.ts ./src/playStoreVersion.test.ts ./src/config.test.ts ./src/lib/aiConfig.test.ts ./src/ocrQuota.test.ts ./src/lib/policyHtml.test.ts ./src/lib/mealFromTemplate.test.ts ./src/lib/mealSlot.test.ts ./src/lib/snackPlacement.test.ts ./src/lib/goalFulfillment.test.ts ./src/lib/statsPeriod.test.ts ./src/lib/statsAggregate.test.ts ./src/lib/userStatsAggregationMeta.test.ts ./src/lib/recommendation.test.ts ./src/lib/referenceWeight.test.ts ./src/lib/weightEntry.test.ts ./src/lib/deactivationReason.test.ts ./src/lib/retention.test.ts ./src/lib/purgeInactive.test.ts ./src/services/mealEntrySuggestions.test.ts ./src/services/ai/aiStatsPeriod.test.ts ./src/services/ai/aiIntent.test.ts ./src/services/ai/aiKnowledgeTopic.test.ts ./src/services/ai/ocrFeedbackService.test.ts ./src/services/ai/aiCoachSummary.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "googleapis": "^144.0.0",
    "jsonwebtoken": "^9.0.3",
    "markdown-it": "^10.0.0",
    "multer": "^1.4.5-lts.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/markdown-it": "^14.1.2",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.10.1",
    "prisma": "^6.19.2",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
