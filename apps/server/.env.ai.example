# DEPRECATED (2026-06-15): AI_ENABLED·LLM·pgvector 설정. 식단 인사이트 전환 후 불필요.
# AI 로컬 데모 — docker-compose.ai.yml (Postgres pgvector + Ollama) 기동 후 merge
# cp apps/server/.env.example .env 후 아래 블록 추가

DATABASE_URL="postgresql://diet:diet@localhost:15432/diet?schema=public"

AI_ENABLED=1
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:3b
EMBED_MODEL=nomic-embed-text
LLM_TIMEOUT_MS=30000

# 벡터 = PostgreSQL pgvector (로컬·Railway 동일). Chroma 사용 안 함.
VECTOR_BACKEND=pgvector

AI_RATE_LIMIT_PER_MIN=10
