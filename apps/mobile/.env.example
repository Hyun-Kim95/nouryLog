# 로컬 AAB/APK(Gradle bundleRelease) 시 모노레포 Metro 루트 고정 — android/app/build.gradle 에서도 설정함
EXPO_NO_METRO_WORKSPACE_ROOT=1

# 로컬: http://localhost:3000 | 프로덕션 EAS 빌드: https://YOUR-PROD-API (필수, EAS Secret)
EXPO_PUBLIC_API_URL="http://localhost:3000"

# 1차 무료 출시: false (Play Billing·react-native-iap 플러그인 off). 구독 재개 시 true + EAS 재빌드.
EXPO_PUBLIC_PLAY_BILLING_ENABLED=false

# 네이티브 SDK 로그인용 (Phase 2 이후)
# - 네이버: 콘솔 > Application > Android 환경 등록 후 ClientID/Secret. iOS URL Scheme 은 콘솔에서 지정한 값.
EXPO_PUBLIC_NAVER_CLIENT_ID=""
EXPO_PUBLIC_NAVER_CLIENT_SECRET=""
EXPO_PUBLIC_NAVER_APP_NAME="nouryLog"
EXPO_PUBLIC_NAVER_IOS_URL_SCHEME="naverlogin-nourylog"
# - 카카오: 디벨로퍼스 > 내 애플리케이션 > 앱 설정 > 앱 키 > 네이티브 앱 키
EXPO_PUBLIC_KAKAO_NATIVE_APP_KEY=""
# - 구글: GCP Console > OAuth 클라이언트 > Web 클라이언트 ID (서버 idToken aud 검증과 동일한 값)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=""

# AdMob (app.config.ts / 네이티브 빌드용 — EXPO_PUBLIC 불필요)
# AdMob 콘솔 > 앱 설정 > 앱 ID (형식: ca-app-pub-xxxxxxxx~xxxxxxxx)
# production EAS 빌드: 샘플 ID 사용 시 빌드 실패 (반드시 본인 앱 ID)
ADMOB_ANDROID_APP_ID=""
ADMOB_IOS_APP_ID=""
# 배너 광고 단위 (앱 JS에서 사용, 출시 전 본인 단위 ID)
EXPO_PUBLIC_ADMOB_BANNER_ANDROID=""
EXPO_PUBLIC_ADMOB_BANNER_IOS=""
