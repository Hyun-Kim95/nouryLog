# API (production build)
# VITE_API_BASE=https://api-server-production-52bc.up.railway.app

# Dev proxy — apps/server PORT와 맞출 것 (기본 vite는 3000). 예: PORT=3002 → 아래 주석 해제
# VITE_DEV_API_TARGET=http://localhost:3002

# Dev / demo login (시연 사이트 — README ?auto=1)
VITE_DEV_EMAIL=user@example.com
VITE_DEV_PASSWORD=changeme
VITE_DEMO_EMAIL=user@example.com
VITE_DEMO_PASSWORD=user123

# Google OAuth web client (same project as mobile)
VITE_GOOGLE_CLIENT_ID=

# Kakao JavaScript key (developers.kakao.com → 앱 키 → JavaScript 키)
VITE_KAKAO_JAVASCRIPT_KEY=

# Naver Login (웹) — redirect URI는 개발자센터에 등록한 값과 동일해야 함
VITE_NAVER_CLIENT_ID=
VITE_NAVER_REDIRECT_URI=http://localhost:5175/demo/oauth/naver

# Optional policy links (settings)
# VITE_PRIVACY_URL=
# VITE_AI_DISCLAIMER_URL=
