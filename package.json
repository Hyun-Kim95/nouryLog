{
  "name": "diet-management",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "mock-internal"
  ],
  "scripts": {
    "dev:server": "npm run dev -w @diet-management/server",
    "dev:admin": "npm run dev -w @diet-management/admin-web",
    "dev:mobile": "npm run start -w mobile",
    "build": "npm run build -w @diet-management/server && npm run build -w @diet-management/admin-web && npm run build -w @diet-management/api-client",
    "generate:api": "npm run generate -w @diet-management/api-client",
    "db:generate": "npm run prisma:generate -w @diet-management/server",
    "db:migrate": "npm run prisma:migrate -w @diet-management/server",
    "stitch:health": "tsx scripts/stitch/01-healthcheck.ts",
    "stitch:generate": "tsx scripts/stitch/02-generate-screens.ts",
    "stitch:apply-ds": "tsx scripts/stitch/03-apply-design-system.ts",
    "stitch:collect": "tsx scripts/stitch/04-collect-screens.ts",
    "stitch:generate-missing": "npm run generate-missing --prefix scripts/stitch",
    "stitch:apply-missing-ds": "npm run apply-missing-ds --prefix scripts/stitch",
    "stitch:collect-missing": "npm run collect-missing --prefix scripts/stitch",
    "stitch:missing:all": "npm run missing:all --prefix scripts/stitch",
    "stitch:generate-split": "npm run generate-split --prefix scripts/stitch",
    "stitch:apply-split-ds": "npm run apply-split-ds --prefix scripts/stitch",
    "stitch:collect-split": "npm run collect-split --prefix scripts/stitch",
    "stitch:split:all": "npm run split:all --prefix scripts/stitch",
    "smoke:dev": "node scripts/dev-smoke/all.mjs",
    "smoke:dev:n": "node scripts/dev-smoke/phase-n.mjs",
    "smoke:dev:p": "node scripts/dev-smoke/phase-p.mjs",
    "smoke:dev:t": "node scripts/dev-smoke/phase-t.mjs",
    "smoke:dev:q": "node scripts/dev-smoke/phase-q-admin.mjs",
    "smoke:dev:r": "node scripts/dev-smoke/phase-r-consent.mjs",
    "smoke:dev:s": "node scripts/dev-smoke/phase-s-social-exchange.mjs",
    "insights:smoke:summary": "node scripts/ai-local/smoke-coach-summary.mjs",
    "insights:smoke:weekly": "node scripts/ai-local/smoke-weekly-report.mjs",
    "insights:smoke:monthly": "node scripts/ai-local/smoke-monthly-report.mjs",
    "seed:demo-user": "tsx apps/server/scripts/seed-demo-user.ts"
  },
  "devDependencies": {
    "@google/stitch-sdk": "^0.2.0",
    "tsx": "^4.21.0"
  },
  "overrides": {
    "entities": "2.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}
