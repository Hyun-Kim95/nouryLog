{
  "name": "diet-management",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "mock-internal"
  ],
  "scripts": {
    "dev:server": "npm run dev -w @diet-management/server",
    "dev:admin": "npm run dev -w @diet-management/admin-web",
    "dev:mobile": "npm run start -w mobile",
    "build": "npm run build -w @diet-management/server && npm run build -w @diet-management/admin-web && npm run build -w @diet-management/api-client",
    "generate:api": "npm run generate -w @diet-management/api-client",
    "db:generate": "npm run prisma:generate -w @diet-management/server",
    "db:migrate": "npm run prisma:migrate -w @diet-management/server"
  }
}
